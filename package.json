{
  "name": "clouddesk-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:generate": "turbo db:generate --filter=@clouddesk/db",
    "db:push": "turbo db:push --filter=@clouddesk/db",
    "db:seed": "turbo db:seed --filter=@clouddesk/db"
  },
  "devDependencies": {
    "turbo": "^2.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
